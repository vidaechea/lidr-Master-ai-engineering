# Backend environment variables
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/estimator

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Internal API key (shared with AI engine) ─────────────────────────────────
INTERNAL_API_KEY=change-me-internal-key

# ── AI engine ────────────────────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8001

# ── Google OAuth2 (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
