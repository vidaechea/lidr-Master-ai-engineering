# --- API Keys ---
# Required if LLM_PROVIDER=openai or litellm
OPENAI_API_KEY=

# Required if LLM_PROVIDER=anthropic or litellm
ANTHROPIC_API_KEY=

# --- Provider & Model ---
# Options: openai | anthropic | litellm
# litellm uses both keys above and handles fallback automatically
LLM_PROVIDER=openai

# Model to use (only relevant for openai and anthropic providers)
# OpenAI:    gpt-4o-mini | gpt-4-turbo | gpt-5.4 | o3-mini | o4-mini
# Anthropic: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
LLM_MODEL=gpt-4o-mini

# --- Application ---
# Execution environment: development | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# --- Optional ---
# Preload a sample transcription in Swagger UI: short | long | (leave empty)
EXAMPLE_FIXTURE=
