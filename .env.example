# ═════════════════════════════════════════════════════════════════════════════
# Consolidated .env.example — All variables from root, backend, and ai-engine
# Copy to .env at the repo root and fill in your values.
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE & PERSISTENCE
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (injected into backend container)
POSTGRES_USER=estimator
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=estimator

# Backend Database URL (overrides POSTGRES_* for docker-compose)
DATABASE_URL=postgresql+asyncpg://estimator:estimator_dev@localhost:5432/estimator

# Redis (for caching and task queue)
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY & AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────

# Backend JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Internal API key shared between backend and ai-engine
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=change_me_in_production

# ─────────────────────────────────────────────────────────────────────────────
# LLM CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# LLM API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM Model Selection (primary and fallback for LiteLLM router)
# OpenAI models:    gpt-4o-mini | gpt-5.4-mini | gpt-5.4 | gpt-4-turbo | o3-mini | o3 | o4-mini
# Anthropic models: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
LLM_MODEL=gpt-4o-mini
LLM_FALLBACK=claude-haiku-4-5-20251001

# LiteLLM Router Configuration (for failover/retry)
ROUTER_NUM_RETRIES=2
ROUTER_TIMEOUT=30.0
ROUTER_RETRY_AFTER=5
ROUTER_ALLOWED_FAILS=2
ROUTER_COOLDOWN_TIME=60

# ─────────────────────────────────────────────────────────────────────────────
# CACHING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Enable caching (requires Redis running and reachable at REDIS_URL)
CACHE_ENABLED=true

# Semantic cache (requires Redis Stack + redisvl)
# SEMANTIC_CACHE_ENABLED=true requires REDIS_URL to point at a Redis Stack instance
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_LOG_ONLY=false

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION ENVIRONMENT & LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# Environment mode
APP_ENV=development

# Logging level
LOG_LEVEL=DEBUG

# AI Engine example fixture (short | medium | long)
EXAMPLE_FIXTURE=short

# ─────────────────────────────────────────────────────────────────────────────
# SERVICE CONNECTIVITY
# ─────────────────────────────────────────────────────────────────────────────

# AI Engine service URL
AI_ENGINE_URL=http://localhost:8001

# CORS Origins (for backend frontend access)
CORS_ORIGINS=["http://localhost:4200","http://localhost:3000"]

