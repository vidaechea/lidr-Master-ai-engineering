# ─────────────────────────────────────────────────────────────────────────────
# ROOT .env.example — shared variables loaded by docker-compose.yml
# Copy to .env at the repo root and fill in your values.
# Service-specific vars also go in estimator-cag/.env and backend/.env.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (injected into backend container) ──────────────────────────────
POSTGRES_USER=estimator
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=estimator

# ── Internal API key shared between backend and ai-engine ─────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=change_me_in_production

# ─────────────────────────────────────────────────────────────────────────────
# estimator-cag/.env  (also set here for docker-compose env pass-through)
# ─────────────────────────────────────────────────────────────────────────────

# --- API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Provider & Model ---
# Options: openai | anthropic | litellm
LLM_PROVIDER=openai
# OpenAI:    gpt-4o-mini | gpt-5.4-mini | gpt-5.4 | o3-mini | o4-mini
# Anthropic: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
LLM_MODEL=gpt-4o-mini

# --- Application ---
APP_ENV=development
LOG_LEVEL=DEBUG
EXAMPLE_FIXTURE=short

# ─────────────────────────────────────────────────────────────────────────────
# backend/.env  (also set here for docker-compose env pass-through)
# ─────────────────────────────────────────────────────────────────────────────

# JWT — generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 — Google (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

