# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Application
APP_ENV=production
LOG_LEVEL=INFO

# LiteLLM Router failover policy
ROUTER_NUM_RETRIES=2
ROUTER_TIMEOUT=30.0
ROUTER_RETRY_AFTER=5
ROUTER_ALLOWED_FAILS=2
ROUTER_COOLDOWN_TIME=60

#REDIS
CACHE_ENABLED=true
REDIS_URL=redis://redis:6379