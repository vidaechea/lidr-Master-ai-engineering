# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Application
APP_ENV=production
LOG_LEVEL=INFO

# LiteLLM Router failover policy
ROUTER_NUM_RETRIES=2
ROUTER_TIMEOUT=30.0
ROUTER_RETRY_AFTER=5
ROUTER_ALLOWED_FAILS=2
ROUTER_COOLDOWN_TIME=60

# REDIS
# Enable caching only when Redis is running and reachable at REDIS_URL.
CACHE_ENABLED=false
REDIS_URL=redis://redis:6379

# Cache — semantic similarity (requires Redis Stack + redisvl)
# SEMANTIC_CACHE_ENABLED=true requires REDIS_URL to point at a Redis Stack instance.
# SEMANTIC_CACHE_LOG_ONLY=true runs in shadow mode (logs hits, never returns cached result).
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_LOG_ONLY=false